# Copy this file and rename it to .env for local development.
# Do not upload your real .env file to GitHub.

APP_NAME=EduMentor AI

# Required for live AI responses
OPENAI_API_KEY=replace_with_your_openai_api_key

# You can change this model if your OpenAI account supports another model.
OPENAI_MODEL=gpt-4o-mini

# For local UI testing without an API key, set DEMO_MODE=true.
# For final submission, keep DEMO_MODE=false.
DEMO_MODE=false
